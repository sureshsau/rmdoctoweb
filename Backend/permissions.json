{
  "user": {
    "label": "User Management",
    "permissions": {
      "user.create": "Create user",
      "user.read.all": "View all users",
      "user.update": "Update user",
      "user.delete": "Delete user"
    }
  },

  "medicine": {
    "label": "Medicine Management",
    "permissions": {
      "medicine.create": "Add medicine",
      "medicine.read": "View medicines",
      "medicine.update": "Update medicine",
      "medicine.delete": "Delete medicine"
    }
  },

  "medicineOrder": {
    "label": "Medicine Order Management",
    "permissions": {
      "medicineOrder.read.all": "View all medicine orders",
      "medicineOrder.assign.rider": "Assign RM Rider to order",
      "medicineOrder.status.update": "Update order status"
    }
  },

  "attendance": {
    "label": "Attendance Management",
    "permissions": {
      "attendance.setup": "Setup attendance for a user",
      "attendance.read.all": "View attendance logs of any user"
    }
  },

  "agent": {
    "label": "Agent Management",
    "permissions": {
      "agent.create": "Create / register an agent",
      "agent.read": "View agents",
      "agent.update": "Update agent"
    }
  },

  "appointment": {
    "label": "Appointment Management",
    "permissions": {
      "appointment.create": "Book an appointment",
      "appointment.read.all": "View all bookings (admin / staff)"
    }
  },

  "rmcoin": {
    "label": "RM Coin Management",
    "permissions": {
      "rmcoin.transfer.toUser": "Admin transfer RM Coins to user",
      "rmcoin.recharge": "Admin recharge RM Coins",
      "rmcoin.logs.admin": "View admin RM Coin logs"
    }
  },

  "rmcredit": {
    "label": "RM Credit Management",
    "permissions": {
      "rmcredit.add": "Add credit to agent",
      "rmcredit.revoke.request": "Initiate credit revoke",
      "rmcredit.revoke.verify": "Verify / confirm credit revoke",
      "rmcredit.read.history": "View admin credit history",
      "rmcredit.read.agent": "View specific agent credit details"
    }
  },

  "employee": {
    "label": "Employee Management",
    "permissions": {
      "employee.read.all": "View all employees",
      "employee.attendance.read.all": "View all employee attendance"
    }
  }
}
